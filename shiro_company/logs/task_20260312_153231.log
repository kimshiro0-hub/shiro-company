     형, 미안! 급하게 보내다 보니 코드를 덜 보냈네. 그리고 들여쓰기 실수도 있었어. 바로 수정해서 다시 보낼게.
     
     `eval` 사용할 때 보안은 `__builtins__` 비활성화로 최대한 제한했고, 나머지는 요구사항대로 다 구현했어.
     
     ```python
     import operator
     
     # 계산 히스토리를 저장할 리스트
     history = []
     
     def calculate(expression):
         """
         주어진 수식을 계산해줘. 보안을 위해 최소한의 내장 함수와 사칙연산만 허용했어.
         """
         try:
             # eval() 함수를 사용하되, 내장 함수(built-ins)는 모두 비활성화하고
             # 로컬 스코프도 비워둬서 임의의 코드 실행을 방지해.
             # 연산자들은 파이썬 자체의 연산자를 사용하므로, 별도로 globals에 추가할 필요 없어.
             # 다만, 수식에 변수나 함수 호출이 포함되지 않도록 주의해야 해.
             result = eval(expression, {"__builtins__": None})
             return result
         except SyntaxError:
             return "오류: 잘못된 수식 형식입니다."
         except ZeroDivisionError:
             return "오류: 0으로 나눌 수 없습니다."
         except Exception as e:
             return f"오류: {e}"
     
     def display_history():
         """
         계산 히스토리를 출력해줘.
         """
         if not history:
             print("\n아직 계산 기록이 없어.\n")
             return
         
         print("\n--- 계산 히스토리 ---")
         for i, entry in enumerate(history):
             print(f"{i + 1}. {entry}")
         print("---------------------\n")
     
     def clear_history():
         """
         계산 히스토리를 초기화해줘.
         """
         global history
         history = []
         print("\n계산 히스토리가 초기화되었어.\n")
     
     def main():
         """
         CLI 계산기 메인 함수.
         """
         print("누나를 위한 CLI 계산기! 반가워:)")
     
         while True:
             print("1. 계산하기")
             print("2. 히스토리 보기")
             print("3. 히스토리 초기화")
             print("4. 종료")
             
             choice = input("어떤 작업을 할까? (1-4): ")
     
             if choice == '1':
                 expression = input("수식을 입력해줘 (예: 2 + 3 * 4 / 2): ")
                 result = calculate(expression)
                 if isinstance(result, (int, float)):
                     history.append(f"{expression} = {result}")
                     print(f"결과: {result}\n")
                 else:
                     print(f"{result}\n") # 오류 메시지 출력
             elif choice == '2':
                 display_history()
             elif choice == '3':
                 clear_history()
             elif choice == '4':
                 print("다음에 또 봐! :)")
                 break
             else:
                 print("잘못된 선택이야. 1에서 4 사이의 숫자를 입력해줘.\n")
     
     if __name__ == "__main__":
         main()
     ```
