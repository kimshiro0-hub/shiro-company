     import pytest
     from daily_gift_generator import DailyGiftGenerator
     
     def test_generator_creation():
         generator = DailyGiftGenerator()
         assert generator is not None
     
     def test_generate_random_gift():
         generator = DailyGiftGenerator()
         gift = generator.generate_gift()
         assert gift is not None
         assert len(gift) > 0
     
     def test_generate_food_gift():
         generator = DailyGiftGenerator()
         gift = generator.generate_gift('food')
         assert gift is not None
     
     def test_generate_digital_gift():
         generator = DailyGiftGenerator()
         gift = generator.generate_gift('digital')
         assert gift is not None
     
     def test_generate_comfort_gift():
         generator = DailyGiftGenerator()
         gift = generator.generate_gift('comfort')
         assert gift is not None
     
     def test_get_gift_message():
         generator = DailyGiftGenerator()
         message = generator.get_gift_message("커피")
         assert "커피" in message
         assert len(message) > 10
     
     def test_invalid_category():
         generator = DailyGiftGenerator()
         gift = generator.generate_gift('invalid_category')
         assert gift is not None  # Should fallback to random
     
     def test_multiple_calls_different_results():
         generator = DailyGiftGenerator()
         gifts = [generator.generate_gift() for _ in range(5)]
         assert len(set(gifts)) > 1  # Should have some variety
     
     def test_message_contains_gift():
         generator = DailyGiftGenerator()
         gift = "초콜릿"
         message = generator.get_gift_message(gift)
         assert isinstance(message, str)
         assert len(message) > 0
