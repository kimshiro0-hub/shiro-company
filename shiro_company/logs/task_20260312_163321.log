     ```test
     import pytest
     import subprocess
     import sys
     from unittest.mock import patch
     import io
     
     def test_main_execution_with_input():
         from todo_app import TodoList
         todo = TodoList()
         assert hasattr(todo, 'add_task')
     
     def test_pause_functionality():
         # input() 함수가 호출되는지 확인
         with patch('builtins.input', return_value=''):
             import todo_app
             # 메인 실행부에 input()이 있는지 확인
     
     def test_demo_output():
         # 데모 실행 시 출력이 있는지 확인
         with patch('sys.stdout', new_callable=io.StringIO) as mock_stdout:
             with patch('builtins.input', return_value=''):
                 exec(open('todo_app.py').read())
             output = mock_stdout.getvalue()
             assert len(output) > 0
     
     def test_encouragement_display():
         from todo_app import TodoList
         todo = TodoList()
         message = todo.get_encouragement()
         assert isinstance(message, str)
         assert len(message) > 0
     
     def test_terminal_friendly_execution():
         # 파일이 터미널에서 실행될 때 적절한 출력이 있는지
         result = subprocess.run([sys.executable, 'todo_app.py'], 
                               input='\n', text=True, capture_output=True, timeout=5)
         assert result.returncode == 0
         assert len(result.stdout) > 0
     ```
     
