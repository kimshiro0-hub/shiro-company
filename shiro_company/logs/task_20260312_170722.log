                     "물 한 잔 마시고 시작하면 더 집중할 수 있어.",
                     "작업 중간에 스트레칭하면 피로가 풀려.",
                     "중요한 일부터 처리하는 습관을 들이면 효율이 올라가.",
                     "매일 할 일 목록을 작성하고 완료하는 습관을 들여봐."
                 ],
                 "fun_fact": [
                     "인간의 뇌는 몸무게의 2%를 차지하지만, 에너지의 20%를 소모한다.",
                     "지구상의 모든 개미를 합치면 인간의 총 무게보다 더 무겁다.",
                     "꿀벌은 날개짓을 1초에 200번 한다.",
                     "코끼리는 점프를 할 수 없는 유일한 포유류다.",
                     "하품은 뇌를 식히는 데 도움이 된다고 알려져 있다."
                 ],
                 "encouragement": [
                     "오늘도 수고했어! 최고야.",
                     "잘하고 있어, 조금만 더 힘내자!",
                     "네 존재만으로도 충분히 빛나.",
                     "어떤 어려움도 극복할 수 있는 힘이 너에겐 있어.",
                     "오늘 하루도 멋지게 마무리하길 바라!"
                 ]
             }
             self._custom_gifts = {
                 "motivation": [],
                 "tip": [],
                 "fun_fact": [],
                 "encouragement": []
             }
     
         def _get_all_gifts(self):
             all_gifts = []
             for category, messages in self._default_gifts.items():
                 for msg in messages:
                     all_gifts.append({'category': category, 'message': msg})
             for category, messages in self._custom_gifts.items():
                 for msg in messages:
                     all_gifts.append({'category': category, 'message': msg})
             return all_gifts
     
         def _get_consistent_gift_for_date(self, target_date: date):
             all_gifts = self._get_all_gifts()
             if not all_gifts:
                 return {'category': 'information', 'message': '선물이 아직 준비되지 않았습니다.'}
     
             # Use date components to create a consistent 'seed' for gift selection
             # This ensures the same date always gets the same gift, regardless of call time
             seed_value = target_date.year * 10000 + target_date.month * 100 + target_date.day
             
             # Consistent selection using modulo
             chosen_index = seed_value % len(all_gifts)
             
             chosen_gift = all_gifts[chosen_index]
             return {
                 'category': chosen_gift['category'],
                 'message': chosen_gift['message'],
                 'date': target_date.strftime('%Y-%m-%d')
             }
     
         def get_todays_gift(self):
             today = datetime.now().date()
             return self._get_consistent_gift_for_date(today)
     
         def get_gift_by_date(self, target_date: date):
             return self._get_consistent_gift_for_date(target_date)
     
         def add_custom_gift(self, category: str, item: str):
             if category in self._custom_gifts:
                 self._custom_gifts[category].append(item)
             else:
                 # If a new category is added, initialize it
                 self._custom_gifts[category] = [item]
         
         # This method is for testing purposes, as per the test case.
         def get_custom_gifts(self):
             return self._custom_gifts
