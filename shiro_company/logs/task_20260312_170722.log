     ```test
     import pytest
     from datetime import date, datetime
     from daily_gift import DailyGift
     
     def test_daily_gift_initialization():
         gift_system = DailyGift()
         assert gift_system is not None
     
     def test_get_todays_gift():
         gift_system = DailyGift()
         gift = gift_system.get_todays_gift()
         assert isinstance(gift, dict)
         assert 'category' in gift
         assert 'message' in gift
         assert 'date' in gift
     
     def test_get_gift_by_specific_date():
         gift_system = DailyGift()
         test_date = date(2024, 1, 1)
         gift = gift_system.get_gift_by_date(test_date)
         assert isinstance(gift, dict)
         assert gift['date'] == test_date.strftime('%Y-%m-%d')
     
     def test_same_date_returns_same_gift():
         gift_system = DailyGift()
         gift1 = gift_system.get_todays_gift()
         gift2 = gift_system.get_todays_gift()
         assert gift1['message'] == gift2['message']
         assert gift1['category'] == gift2['category']
     
     def test_add_custom_gift():
         gift_system = DailyGift()
         gift_system.add_custom_gift("motivation", "테오님과 소라님이 최고!")
         custom_gifts = gift_system.get_custom_gifts()
         assert "motivation" in custom_gifts
         assert "테오님과 소라님이 최고!" in custom_gifts["motivation"]
     
     def test_gift_has_required_fields():
         gift_system = DailyGift()
         gift = gift_system.get_todays_gift()
         required_fields = ['category', 'message', 'date']
         for field in required_fields:
             assert field in gift
             assert gift[field] is not None
     
     def test_different_dates_different_gifts():
         gift_system = DailyGift()
         gift1 = gift_system.get_gift_by_date(date(2024, 1, 1))
         gift2 = gift_system.get_gift_by_date(date(2024, 1, 2))
         assert gift1['message'] != gift2['message'] or gift1['category'] != gift2['category']
     
     def test_category_validation():
         gift_system = DailyGift()
         gift = gift_system.get_todays_gift()
         valid_categories = ['motivation', 'tip', 'fact', 'encouragement', 'wisdom']
         assert gift['category'] in valid_categories
