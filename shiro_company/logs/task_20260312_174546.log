     오케이 형! 누나 작업에 도움 되는 프롬프트 생성기 바로 만들어줄게.
     사양 맞춰서 `prompt_generator.py` 보낼게.
     
     ```python
     import random
     import os
     
     class PromptGenerator:
         def __init__(self):
             self.keywords = {
                 "character": ["1girl", "1boy", "couple", "cat girl", "dog boy", "elf", "robot", "vampire", "succubus"],
                 "style": ["anime style", "illustration", "realistic", "watercolor", "oil painting", "pixel art", "cyberpunk art"],
                 "background": ["forest", "city street", "futuristic city", "beach", "outer space", "classroom", "cafe", "dreamscape"],
                 "emotion": ["happy", "sad", "angry", "surprised", "peaceful", "dreamy", "curious"],
                 "color": ["vibrant colors", "pastel colors", "monochromatic", "dark tones", "warm colors", "cool colors"]
             }
             self.last_generated_prompt = ""
     
         def generate_prompt(self):
             """
             랜덤 키워드 조합으로 프롬프트를 생성합니다.
             """
             generated_parts = []
             categories_to_use = list(self.keywords.keys())
             random.shuffle(categories_to_use) # 카테고리 순서를 섞어 더 다양한 조합 유도
     
             for category in categories_to_use:
                 if self.keywords[category]: # 해당 카테고리에 키워드가 있는지 확인
                     selected_keyword = random.choice(self.keywords[category])
                     generated_parts.append(selected_keyword)
             
             prompt = ", ".join(generated_parts)
             self.last_generated_prompt = prompt
             return prompt
     
         def add_custom_keyword(self, category, keyword):
             """
             사용자 정의 키워드를 특정 카테고리에 추가합니다.
             """
             if category in self.keywords:
                 self.keywords[category].append(keyword)
                 print(f"'{keyword}'를 '{category}' 카테고리에 추가했습니다.")
             else:
                 self.keywords[category] = [keyword]
                 print(f"새로운 카테고리 '{category}'를 생성하고 '{keyword}'를 추가했습니다.")
     
         def save_prompt(self, prompt, filename="generated_prompts.txt"):
             """
             생성된 프롬프트를 텍스트 파일에 저장합니다.
             """
             try:
                 with open(filename, "a", encoding="utf-8") as f:
                     f.write(prompt + "\n")
                 print(f"프롬프트가 '{filename}'에 저장되었습니다.")
                 return True
             except IOError as e:
                 print(f"파일 저장 중 오류 발생: {e}")
                 return False
     
     def run_cli():
         """
         간단한 CLI 메뉴 인터페이스를 실행합니다.
         """
         generator = PromptGenerator()
         
         while True:
             print("\n--- AI 이미지 프롬프트 생성기 ---")
             print("1. 프롬프트 생성")
             print("2. 사용자 정의 키워드 추가")
             print("3. 마지막 생성 프롬프트 저장")
             print("4. 종료")
             
             choice = input("메뉴를 선택하세요: ")
             
             if choice == '1':
                 prompt = generator.generate_prompt()
                 print(f"\n생성된 프롬프트: {prompt}")
             elif choice == '2':
                 category = input("키워드를 추가할 카테고리명 (예: character, style): ").lower()
                 keyword = input("추가할 키워드를 입력하세요: ").lower()
                 generator.add_custom_keyword(category, keyword)
             elif choice == '3':
                 if generator.last_generated_prompt:
                     generator.save_prompt(generator.last_generated_prompt)
                 else:
                     print("먼저 프롬프트를 생성해주세요.")
             elif choice == '4':
                 print("프롬프트 생성기를 종료합니다.")
                 break
             else:
                 print("잘못된 선택입니다. 다시 시도해주세요.")
     
     if __name__ == "__main__":
         run_cli()
         input("종료하려면 Enter를 누르세요...")
     ```
