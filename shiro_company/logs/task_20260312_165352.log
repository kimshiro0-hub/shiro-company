     ```python
     # pause_terminal.py
     import os
     import sys
     from functools import wraps
     
     class PauseTerminal:
         def __init__(self):
             self.os_name = sys.platform
     
         def _get_pause_input(self, message: str = "아무 키나 누르세요..."):
             """내부적으로 input()을 사용하여 터미널을 일시정지합니다."""
             try:
                 input(message)
             except EOFError: # 파이프 등으로 실행될 때 input 에러 방지
                 pass
     
         def pause_with_message(self, message: str):
             """지정된 메시지와 함께 터미널을 일시정지합니다."""
             print(message)
             self._get_pause_input()
     
         def pause_simple(self):
             """기본 메시지와 함께 터미널을 일시정지합니다."""
             self._get_pause_input("계속하려면 Enter 키를 누르세요...")
     
         def auto_pause_decorator(self):
             """
             함수 실행 후 자동으로 터미널을 일시정지시키는 데코레이터입니다.
             """
             def decorator(func):
                 @wraps(func)
                 def wrapper(*args, **kwargs):
                     result = func(*args, **kwargs)
                     print(f"'{func.__name__}' 함수 실행이 완료되었습니다.")
                     self.pause_simple()
                     return result
                 return wrapper
             return decorator
     
         def clear_and_pause(self):
             """터미널 화면을 클리어하고 일시정지합니다."""
             if self.os_name.startswith('win'):
                 os.system('cls')
             else:
                 os.system('clear')
             self._get_pause_input("화면이 지워졌습니다. 계속하려면 Enter 키를 누르세요...")
     
     ```
