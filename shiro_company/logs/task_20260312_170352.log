     형, 터미널 종료 문제를 해결하는 `TerminalKeeper` 클래스 구현입니다.
     ```python
     import sys
     import atexit
     
     class TerminalKeeper:
         def __init__(self, auto_pause=True):
             self.auto_pause = auto_pause
             if self.auto_pause:
                 atexit.register(self._exit_pause)
     
         def wait_for_input(self, message="계속하려면 Enter를 누르세요..."):
             """사용자 입력을 기다려 터미널이 닫히는 것을 방지합니다."""
             input(message)
     
         def keep_alive(self):
             """터미널을 유지하기 위해 입력을 기다립니다."""
             self.wait_for_input()
     
         def _exit_pause(self):
             """프로그램 종료 시 자동으로 입력을 기다립니다."""
             # 이 함수는 atexit에 등록되어 프로그램 정상 종료 시 호출됩니다.
             # sys.excepthook으로 예외 종료 시에도 작동하게 할 수 있지만,
             # 여기서는 테스트 스펙에 맞춰 일반 종료를 처리합니다.
             if sys.stdout.isatty(): # 터미널에서 실행될 때만 작동
                 self.wait_for_input("프로그램이 종료되었습니다. 창을 닫으려면 Enter를 누르세요...")
     
         def pause_on_exit(self):
             """종료 시 일시 정지 기능을 활성화합니다. __init__에서 auto_pause가 True면 이미 활성화됩니다."""
             if not self.auto_pause:
                 atexit.register(self._exit_pause)
                 self.auto_pause = True # 한 번 등록되면 다시 등록할 필요 없으므로 상태 변경
     
         def run_with_pause(self, func, *args, **kwargs):
             """특정 함수를 실행한 후, 설정에 따라 터미널을 일시 정지합니다."""
             try:
                 result = func(*args, **kwargs)
             except Exception as e:
                 print(f"함수 실행 중 오류 발생: {e}")
                 raise
             finally:
                 if self.auto_pause and sys.stdout.isatty(): # 함수 실행 후 일시 정지 (exit hook과 별개로)
                     self.wait_for_input("함수 실행이 완료되었습니다. 계속하려면 Enter를 누르세요...")
             return result
     
     # 모듈이 직접 실행될 경우, 간단한 테스트를 위한 코드 (필요하면 주석 해제)
     if __name__ == "__main__":
         print("TerminalKeeper를 테스트합니다.")
         keeper = TerminalKeeper() # auto_pause=True로 초기화
         
         def my_function(name):
             print(f"안녕하세요, {name}님!")
             return f"Hello, {name}!"
     
         # keeper.run_with_pause(my_function, "테오")
         # print("run_with_pause 호출 후")
     
         # 수동으로 유지하려면
         # keeper.keep_alive()
     
         print("프로그램이 곧 종료됩니다. auto_pause 덕분에 창이 바로 닫히지 않을 것입니다.")
         # 프로그램 종료 시 _exit_pause가 호출됨
     ```
