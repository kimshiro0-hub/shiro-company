  [17:04:45] [테오]
     형, 실패한 테스트 두 개 수정했어요! `run_with_pause`에서 `isatty()` 조건 빼고, `pause_on_exit`에선 `input()` 호출 후 `sys.exit(0)` 추가했어요. 중복 호출 방지 로직도 넣었습니다.
     ```python
     import sys
     import atexit
     
     class TerminalKeeper:
         _exit_handled_by_pause_on_exit = False # 클래스 레벨 플래그로 중복 실행 방지
     
         def __init__(self, auto_pause=True):
             self.auto_pause = auto_pause
             if self.auto_pause:
                 atexit.register(self._exit_pause)
     
         def wait_for_input(self, message="계속하려면 Enter를 누르세요..."):
             """사용자 입력을 기다려 터미널이 닫히는 것을 방지합니다."""
             input(message)
     
         def keep_alive(self):
             """터미널을 유지하기 위해 입력을 기다립니다."""
             self.wait_for_input()
     
         def _exit_pause(self):
             """프로그램 종료 시 자동으로 입력을 기다립니다. (atexit 훅용)"""
             # pause_on_exit()에 의해 종료가 이미 처리되었다면 중복 실행 방지
             if not TerminalKeeper._exit_handled_by_pause_on_exit and sys.stdout.isatty():
                 self.wait_for_input("프로그램이 종료되었습니다. 창을 닫으려면 Enter를 누르세요...")
     
         def pause_on_exit(self):
             """즉시 프로그램을 일시 정지하고 종료합니다."""
             # 이 메서드가 호출되면, atexit 훅이 중복 실행되지 않도록 플래그를 설정
             TerminalKeeper._exit_handled_by_pause_on_exit = True
             # 테스트 요구사항에 맞춰 input()을 항상 호출하도록 isatty() 제거
             self.wait_for_input("프로그램이 종료되었습니다. 창을 닫으려면 Enter를 누르세요...")
             sys.exit(0) # 요구사항: sys.exit(0) 호출 추가
     
         def run_with_pause(self, func, *args, **kwargs):
             """특정 함수를 실행한 후, 설정에 따라 터미널을 일시 정지합니다."""
             try:
                 result = func(*args, **kwargs)
             except Exception as e:
                 print(f"함수 실행 중 오류 발생: {e}")
                 raise
             finally:
                 # 요구사항: auto_pause=True일 때 항상 입력 대기 (sys.stdout.isatty() 조건 제거)
                 if self.auto_pause:
                     self.wait_for_input("함수 실행이 완료되었습니다. 계속하려면 Enter를 누르세요...")
             return result
     ```
