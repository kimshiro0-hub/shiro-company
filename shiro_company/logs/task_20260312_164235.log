     ```test
     import pytest
     from datetime import datetime, timedelta
     from daily_helper import DailyHelper
     
     def test_add_task():
         helper = DailyHelper()
         helper.add_task("코드 리뷰", "high")
         tasks = helper.show_tasks()
         assert "코드 리뷰" in str(tasks)
     
     def test_complete_task():
         helper = DailyHelper()
         helper.add_task("테스트 작성")
         result = helper.complete_task("테스트 작성")
         assert result == True
     
     def test_complete_nonexistent_task():
         helper = DailyHelper()
         result = helper.complete_task("없는 작업")
         assert result == False
     
     def test_priority_ordering():
         helper = DailyHelper()
         helper.add_task("낮은 작업", "low")
         helper.add_task("높은 작업", "high")
         helper.add_task("보통 작업", "normal")
         tasks = helper.show_tasks()
         # high priority가 먼저 나와야 함
         assert tasks.index("높은 작업") < tasks.index("보통 작업")
     
     def test_get_work_schedule():
         helper = DailyHelper()
         # 임의 날짜로 테스트
         schedule = helper.get_work_schedule("2024-01-15")
         assert schedule in ["근무일", "쉬는날"]
     
     def test_empty_task_list():
         helper = DailyHelper()
         tasks = helper.show_tasks()
         assert len(tasks) == 0
     
     def test_invalid_priority():
         helper = DailyHelper()
         helper.add_task("테스트", "invalid")
         # invalid priority는 "normal"로 처리되어야 함
         tasks = helper.show_tasks()
         assert len(tasks) == 1
     
     def test_time_until_work():
         helper = DailyHelper()
         time_left = helper.time_until_work()
         # 결과가 문자열이고 "시간" 또는 "분"이 포함되어야 함
         assert isinstance(time_left, str)
         assert "시간" in time_left or "분" in time_left
     ```
     
