     소라 형, 말씀하신 `add_task`, `complete_task`, `show_tasks` 메서드를 구현했어요. 우선순위 매핑과 완료된 작업 제거, 그리고 우선순위 정렬까지 신경 써서 코드를 완성했습니다. `daily_helper.py` 파일의 업데이트된 내용입니다.
     
     ```python
     from datetime import datetime, date, timedelta
     
     class DailyHelper:
         def __init__(self):
             self.tasks = []  # 각 태스크는 {"name": "Task Name", "priority": "high"} 형태
             self.priority_map = {"high": 3, "normal": 2, "low": 1} # 높은 숫자가 높은 우선순위
     
         def add_task(self, task_name, priority="normal"):
             # 유효하지 않은 우선순위는 normal로 처리
             if priority not in self.priority_map:
                 priority = "normal"
             self.tasks.append({"name": task_name, "priority": priority})
         
         def complete_task(self, task_name):
             initial_task_count = len(self.tasks)
             # 해당 이름의 태스크를 찾아서 제거
             self.tasks = [task for task in self.tasks if task["name"] != task_name]
             # 태스크가 실제로 제거되었는지 여부 반환
             return len(self.tasks) < initial_task_count
         
         def show_tasks(self):
             # 우선순위 맵을 기준으로 정렬 (내림차순, high -> normal -> low)
             sorted_tasks = sorted(
                 self.tasks, 
                 key=lambda x: self.priority_map.get(x["priority"], self.priority_map["normal"]), 
                 reverse=True
             )
             # 태스크 이름만 추출하여 리스트로 반환
             return [task["name"] for task in sorted_tasks]
         
         def get_work_schedule(self, date_str):
             # 이 메서드는 현재 골격 유지
             return "근무일"
         
         def time_until_work(self):
             # 이 메서드는 현재 골격 유지
             return "2시간"
     ```
