     ```python
     import json
     import os
     
     class PromptTemplate:
         def __init__(self, name: str, category: str, prompt_content: str, tags: list = None):
             if not isinstance(name, str) or not name.strip():
                 raise ValueError("템플릿 이름은 비어 있을 수 없습니다.")
             if not isinstance(category, str) or not category.strip():
                 raise ValueError("카테고리는 비어 있을 수 없습니다.")
             
             self.name = name.strip()
             self.category = category.strip()
             self.prompt_content = prompt_content
             self.tags = sorted(list(set([t.strip().lower() for t in tags if t.strip()]))) if tags else []
     
         def to_dict(self):
             return {"name": self.name, "category": self.category, "prompt_content": self.prompt_content, "tags": self.tags}
     
         @classmethod
         def from_dict(cls, data):
             return cls(data["name"], data["category"], data["prompt_content"], data.get("tags", []))
     
     class PromptManager:
         def __init__(self):
             self.templates = []
         
         def add_template(self, template):
             for i, t in enumerate(self.templates):
                 if t.name == template.name:
                     self.templates[i] = template
                     return
             self.templates.append(template)
         
         def search_templates(self, query):
             return [t for t in self.templates if query.lower() in t.name.lower()]
         
         def filter_by_category(self, category):
             return [t for t in self.templates if t.category == category]
         
         def search_by_tag(self, tag):
             return [t for t in self.templates if tag.lower() in t.tags]
         
         def delete_template(self, name):
             self.templates = [t for t in self.templates if t.name != name]
         
         def save_templates(self, filename):
             with open(filename, 'w', encoding='utf-8') as f:
                 json.dump([t.to_dict() for t in self.templates], f, ensure_ascii=False, indent=2)
         
         def load_templates(self, filename):
             if os.path.exists(filename):
                 with open(filename, 'r', encoding='utf-8') as f:
                     data = json.load(f)
                     self.templates = [PromptTemplate.from_dict(d) for d in data]
     
     if __name__ == "__main__":
         print("NovelAI 프롬프트 템플릿 관리자")
         manager = PromptManager()
         template = PromptTemplate("cute_girl", "character", "1girl, cute, kawaii", ["anime", "cute"])
         manager.add_template(template)
         print(f"템플릿 추가됨: {template.name}")
         print(f"총 템플릿 수: {len(manager.templates)}")
         input("종료하려면 Enter를 누르세요...")
     ```
     
