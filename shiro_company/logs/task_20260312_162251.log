     import pytest
     from todo_app import TodoApp
     
     def test_add_task():
         app = TodoApp()
         task_id = app.add_task("코딩하기")
         assert task_id == 1
         assert len(app.get_tasks()) == 1
     
     def test_add_multiple_tasks():
         app = TodoApp()
         id1 = app.add_task("운동하기")
         id2 = app.add_task("책읽기")
         assert id1 == 1
         assert id2 == 2
         assert len(app.get_tasks()) == 2
     
     def test_remove_task():
         app = TodoApp()
         task_id = app.add_task("삭제할 일")
         app.remove_task(task_id)
         assert len(app.get_tasks()) == 0
     
     def test_mark_complete():
         app = TodoApp()
         task_id = app.add_task("완료할 일")
         app.mark_complete(task_id)
         completed = app.get_completed_tasks()
         assert len(completed) == 1
         assert completed[0]["completed"] == True
     
     def test_get_pending_tasks():
         app = TodoApp()
         app.add_task("미완료1")
         id2 = app.add_task("완료예정")
         app.mark_complete(id2)
         pending = app.get_pending_tasks()
         assert len(pending) == 1
         assert pending[0]["task"] == "미완료1"
     
     def test_remove_nonexistent_task():
         app = TodoApp()
         with pytest.raises(ValueError):
             app.remove_task(999)
     
     def test_mark_complete_nonexistent_task():
         app = TodoApp()
         with pytest.raises(ValueError):
             app.mark_complete(999)
     
     def test_empty_task_string():
         app = TodoApp()
         with pytest.raises(ValueError):
             app.add_task("")
     
     def test_task_structure():
         app = TodoApp()
         task_id = app.add_task("구조 확인")
         tasks = app.get_tasks()
         task = tasks[0]
         assert "id" in task
         assert "task" in task
         assert "completed" in task
