     ```python
     class TodoApp:
         def __init__(self):
             self.tasks = []
             self.next_id = 1
     
         def _find_task_index(self, task_id: int) -> int:
             """내부용: task_id로 인덱스를 찾아 반환합니다. 없으면 ValueError를 발생시킵니다."""
             for i, task in enumerate(self.tasks):
                 if task["id"] == task_id:
                     return i
             raise ValueError(f"Task with ID {task_id} not found.")
     
         def add_task(self, task: str) -> int:
             """
             새로운 할 일을 추가합니다.
             :param task: 할 일 내용
             :return: 할 일 ID
             :raises ValueError: 할 일 내용이 비어있을 경우
             """
             if not task or task.strip() == "":
                 raise ValueError("Task cannot be empty")
             
             new_task = {"id": self.next_id, "task": task, "completed": False}
             self.tasks.append(new_task)
             self.next_id += 1
             return new_task["id"]
     
         def remove_task(self, task_id: int):
             """
             할 일을 삭제합니다.
             :param task_id: 삭제할 할 일 ID
             :raises ValueError: 해당 ID의 할 일이 없을 경우
             """
             index = self._find_task_index(task_id)
             del self.tasks[index]
     
         def mark_complete(self, task_id: int):
             """
             할 일을 완료 상태로 변경합니다.
             :param task_id: 완료할 할 일 ID
             :raises ValueError: 해당 ID의 할 일이 없을 경우
             """
             index = self._find_task_index(task_id)
             self.tasks[index]["completed"] = True
     
         def get_tasks(self) -> list:
             """
             전체 할 일 목록을 조회합니다.
             :return: 모든 할 일 목록 (ID, 내용, 완료 여부 포함)
             """
             return [task.copy() for task in self.tasks]
     
         def get_pending_tasks(self) -> list:
             """
             미완료된 할 일 목록을 조회합니다.
             :return: 미완료 할 일 목록
             """
             return [task.copy() for task in self.tasks if not task["completed"]]
     
         def get_completed_tasks(self) -> list:
             """
             완료된 할 일 목록을 조회합니다.
             :return: 완료된 할 일 목록
             """
             return [task.copy() for task in self.tasks if task["completed"]]
     
