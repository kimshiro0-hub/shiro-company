                 # 기타 일반 선물
                 {"name": "예쁜 머그컵", "price": 12000, "categories": ["home", "drink"], "interests": ["general"], "occasion_suitability": ["random"]},
                 {"name": "향기 좋은 핸드크림 세트", "price": 20000, "categories": ["beauty", "practical"], "interests": ["general"], "occasion_suitability": ["random"]},
