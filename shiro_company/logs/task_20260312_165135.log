         def recommend_gifts(self, occasion: str, budget: int, interests: list) -> list:
             if not self.validate_budget(budget):
                 return []
     
             # 1차 필터링: 예산 내에 있는 선물만 선택
             eligible_gifts = [
                 gift for gift in self.gifts_db if gift["price"] <= budget
             ]
     
             # 관심사 및 상황에 따른 가중치 부여 (간단한 매칭 로직)
             scored_gifts = []
             for gift in eligible_gifts:
                 score = 0
                 
                 # 관심사 일치 점수 (대소문자 무시)
                 lower_interests = [i.lower() for i in interests]
                 for gift_interest in gift["interests"]:
                     if gift_interest.lower() in lower_interests:
                         score += 5
                 
                 # 상황 일치 점수 (대소문자 무시)
                 lower_occasion_tags = [tag.lower() for tag in gift["occasion_tags"]]
                 if occasion.lower() in lower_occasion_tags:
                     score += 3 
                 
                 # 기본 점수 (모든 예산 내 선물에 적용)
                 score += 1 
     
                 scored_gifts.append((gift, score))
     
             # 점수 기준으로 내림차순 정렬, 점수가 같으면 가격 낮은 순
             scored_gifts.sort(key=lambda x: (x[1], -x[0]['price']), reverse=True)
     
             # 상위 N개 (최대 5개) 추천
             recommended = [item[0] for item in scored_gifts[:5]]
             
             # 만약 아무것도 추천되지 않았다면, 예산 내에서 저렴한 선물 3개 반환 (fallback)
             if not recommended and eligible_gifts:
                 eligible_gifts.sort(key=lambda x: x['price'])
                 return eligible_gifts[:3]
             
             return recommended
     
         def get_gift_categories(self) -> list:
             categories = set()
             for gift in self.gifts_db:
                 categories.add(gift["category"])
             return sorted(list(categories))
     
         def validate_budget(self, budget: int) -> bool:
             return isinstance(budget, (int, float)) and budget > 0
     
