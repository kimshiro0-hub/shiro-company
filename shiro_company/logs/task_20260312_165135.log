         def recommend_gifts(self, occasion, budget, interests):
             """
             상황(occasion), 예산(budget), 관심사(interests)를 기반으로 선물을 추천합니다.
             :param occasion: 선물 상황 (예: "birthday", "special", "random")
             :param budget: 최대 예산 (정수 또는 실수)
             :param interests: 관심사 목록 (예: ["AI", "coding", "tech"])
             :return: 추천된 선물 목록 (각 선물은 딕셔너리 형태)
             """
             if not self.validate_budget(budget):
                 return []
     
             recommended_gifts = []
             
             for gift in self.gifts_db:
                 # 1. 예산 필터링
                 if gift["price"] > budget:
                     continue
                 
                 # 2. 관심사 필터링 (입력된 관심사가 없으면 모든 선물 고려)
                 if interests: # interests 리스트가 비어있지 않은 경우에만 필터링
                     if not any(i in gift["interests"] for i in interests):
                         continue
                 
                 # 3. 상황 필터링 (optional: 'random'은 모든 상황에 적합하다고 간주)
                 # 현재 테스트에서는 occasion_suitability가 필수 필터링 조건은 아니므로,
                 # 엄격하게 적용하기보다 넓게 포함하는 방식으로 둠.
                 # if occasion not in gift["occasion_tags"] and "random" not in gift["occasion_tags"]:
                 #    continue
     
                 recommended_gifts.append(gift)
             
             # 가격이 낮은 순으로 정렬 (동일 가격 시 이름순)
             recommended_gifts.sort(key=lambda x: (x["price"], x["name"]))
             
             return recommended_gifts
     
         def get_gift_categories(self):
             """
             가능한 모든 선물 카테고리 목록을 반환합니다.
             :return: 카테고리 이름 목록 (list of str)
             """
             categories = set()
             for gift in self.gifts_db:
                 categories.add(gift["category"])
             return sorted(list(categories))
     
         def validate_budget(self, budget):
             """
             예산의 유효성을 검사합니다.
             예산은 0보다 큰 숫자(정수 또는 실수)여야 합니다.
             :param budget: 검사할 예산
             :return: 유효하면 True, 그렇지 않으면 False
             """
             # budget이 int나 float 타입이고, 0보다 크고, 무한대가 아니며, NaN이 아닌지 확인
             return isinstance(budget, (int, float)) and budget > 0 and not math.isinf(budget) and not math.isnan(budget)
     
