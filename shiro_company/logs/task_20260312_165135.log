     ```test
     import pytest
     from gift_recommender import GiftRecommender
     
     def test_recommend_gifts_birthday():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("birthday", 50000, ["AI", "coding"])
         assert len(gifts) > 0
         assert isinstance(gifts, list)
     
     def test_recommend_gifts_low_budget():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("random", 10000, ["books"])
         assert len(gifts) > 0
         assert all(gift['price'] <= 10000 for gift in gifts)
     
     def test_recommend_gifts_high_budget():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("special", 200000, ["tech"])
         assert len(gifts) > 0
     
     def test_get_gift_categories():
         recommender = GiftRecommender()
         categories = recommender.get_gift_categories()
         assert "tech" in categories
         assert "books" in categories
         assert isinstance(categories, list)
     
     def test_validate_budget_valid():
         recommender = GiftRecommender()
         assert recommender.validate_budget(50000) == True
         assert recommender.validate_budget(1000) == True
     
     def test_validate_budget_invalid():
         recommender = GiftRecommender()
         assert recommender.validate_budget(-1000) == False
         assert recommender.validate_budget(0) == False
     
     def test_recommend_gifts_empty_interests():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("birthday", 30000, [])
         assert len(gifts) > 0
     
     def test_recommend_gifts_multiple_interests():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("appreciation", 80000, ["AI", "convenience", "travel"])
         assert len(gifts) > 0
     
     def test_gift_format():
         recommender = GiftRecommender()
         gifts = recommender.recommend_gifts("random", 50000, ["tech"])
         for gift in gifts:
             assert 'name' in gift
             assert 'price' in gift
             assert 'description' in gift
