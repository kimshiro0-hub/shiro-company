     import pytest
     from todo_list import TodoList
     
     def test_add_task():
         todo = TodoList()
         task_id = todo.add_task("Buy groceries")
         assert task_id == 1
         assert len(todo.get_all_tasks()) == 1
     
     def test_add_multiple_tasks():
         todo = TodoList()
         id1 = todo.add_task("Task 1")
         id2 = todo.add_task("Task 2")
         assert id1 == 1
         assert id2 == 2
         assert len(todo.get_all_tasks()) == 2
     
     def test_complete_task():
         todo = TodoList()
         task_id = todo.add_task("Study Python")
         todo.complete_task(task_id)
         tasks = todo.get_all_tasks()
         assert tasks[0]['completed'] == True
     
     def test_remove_task():
         todo = TodoList()
         task_id = todo.add_task("Delete me")
         todo.remove_task(task_id)
         assert len(todo.get_all_tasks()) == 0
     
     def test_get_pending_tasks():
         todo = TodoList()
         id1 = todo.add_task("Pending task")
         id2 = todo.add_task("Complete task")
         todo.complete_task(id2)
         pending = todo.get_pending_tasks()
         assert len(pending) == 1
         assert pending[0]['id'] == id1
     
     def test_get_completed_tasks():
         todo = TodoList()
         id1 = todo.add_task("Task 1")
         id2 = todo.add_task("Task 2")
         todo.complete_task(id1)
         completed = todo.get_completed_tasks()
         assert len(completed) == 1
         assert completed[0]['id'] == id1
     
     def test_remove_nonexistent_task():
         todo = TodoList()
         result = todo.remove_task(999)
         assert result == False
     
     def test_complete_nonexistent_task():
         todo = TodoList()
         result = todo.complete_task(999)
         assert result == False
     
     def test_empty_todo_list():
         todo = TodoList()
         assert len(todo.get_all_tasks()) == 0
         assert len(todo.get_pending_tasks()) == 0
         assert len(todo.get_completed_tasks()) == 0
