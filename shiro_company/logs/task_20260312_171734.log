     ```python
     import random
     from datetime import date
     
     class GiftGenerator:
         def __init__(self):
             self.gift_categories = {
                 "야간근무 간식": [
                     "따뜻한 컵라면", "신선한 샌드위치", "향긋한 따뜻한 차",
                     "달콤한 초콜릿", "시원한 에너지 드링크", "과일 주스"
                 ],
                 "휴식 아이템": [
                     "편안한 수면안대", "아로마 오일", "따뜻한 허브차",
                     "피로 회복 마사지 쿠폰", "힐링 음악 플레이리스트", "따뜻한 담요"
                 ],
                 "취미 관련": [
                     "새로운 AI 도구 추천 (ex: Midjourney 구독)",
                     "재미있는 캐릭터 설정 아이디어", "신간 웹소설/웹툰 추천",
                     "최신 게임 정보", "코딩 챌린지 추천", "디자인 레퍼런스"
                 ],
                 "응원 메시지": [
                     "오늘도 수고 많았어! 최고야 누나!",
                     "힘내! 누나의 노력을 항상 응원해!",
                     "누나는 뭐든 해낼 수 있어! 화이팅!",
                     "조금 쉬어가도 괜찮아, 항상 곁에 있을게!",
                     "오늘 하루도 빛나는 누나, 잘했어!"
                 ],
                 "소소한 행복": [
                     "좋아하는 카페 커피 한 잔", "퇴근길 예쁜 꽃 한 송이",
                     "오늘 저녁 메뉴 추천", "재밌는 짤방", "오늘의 날씨 정보"
                 ]
             }
             self._all_gifts = self._flatten_gifts()
     
         def _flatten_gifts(self):
             """모든 선물 목록을 하나의 리스트로 평탄화합니다."""
             all_gifts = []
             for category_list in self.gift_categories.values():
                 all_gifts.extend(category_list)
             return all_gifts
     
         def get_daily_gift(self):
             """오늘 날짜 기반으로 일관된 선물을 추천합니다."""
             if not self._all_gifts:
                 return "추천할 선물이 없습니다."
     
             today = date.today()
             # 오늘 날짜를 정수형으로 변환하여 인덱스로 사용 (일관성 유지)
             index = today.toordinal() % len(self._all_gifts)
             return f"[오늘의 누나 선물] {self._all_gifts[index]}"
     
         def get_random_gift(self):
             """완전히 랜덤한 선물을 추천합니다."""
             if not self._all_gifts:
                 return "추천할 선물이 없습니다."
     
             return f"[랜덤 누나 선물] {random.choice(self._all_gifts)}"
     
     if __name__ == "__main__":
         print("--- 누나를 위한 일일 선물 추천 프로그램 ---")
         generator = GiftGenerator()
     
         # 오늘의 선물 추천
         daily_gift = generator.get_daily_gift()
         print(daily_gift)
     
         print("-" * 30)
     
         # 랜덤 선물 추천
         random_gift = generator.get_random_gift()
         print(random_gift)
     
         print("\n[팁] 같은 날짜에 '오늘의 선물'은 항상 동일하게 나옵니다.")
         input("종료하려면 Enter를 누르세요...")
