     import pytest
     from todo_app import TodoList
     
     def test_add_task():
         todo = TodoList()
         todo.add_task("코딩 공부하기")
         tasks = todo.get_tasks()
         assert len(tasks) == 1
         assert tasks[0]['task'] == "코딩 공부하기"
         assert tasks[0]['completed'] == False
     
     def test_remove_task():
         todo = TodoList()
         todo.add_task("운동하기")
         todo.remove_task(0)
         assert len(todo.get_tasks()) == 0
     
     def test_complete_task():
         todo = TodoList()
         todo.add_task("독서하기")
         todo.complete_task(0)
         tasks = todo.get_tasks()
         assert tasks[0]['completed'] == True
     
     def test_get_pending_tasks():
         todo = TodoList()
         todo.add_task("요리하기")
         todo.add_task("청소하기")
         todo.complete_task(0)
         pending = todo.get_pending_tasks()
         assert len(pending) == 1
         assert pending[0]['task'] == "청소하기"
     
     def test_get_completed_tasks():
         todo = TodoList()
         todo.add_task("영화보기")
         todo.complete_task(0)
         completed = todo.get_completed_tasks()
         assert len(completed) == 1
         assert completed[0]['completed'] == True
     
     def test_invalid_index_remove():
         todo = TodoList()
         with pytest.raises(IndexError):
             todo.remove_task(0)
     
     def test_invalid_index_complete():
         todo = TodoList()
         with pytest.raises(IndexError):
             todo.complete_task(0)
     
     def test_encouragement_message():
         todo = TodoList()
         message = todo.get_encouragement()
         assert isinstance(message, str)
         assert len(message) > 0
