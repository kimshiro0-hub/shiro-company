     초기 TaskManager 클래스 구현입니다.
     ```python
     class TaskManager:
         def __init__(self):
             self.tasks = {}
             self.next_task_id = 1
     
         def add_task(self, title, priority="normal"):
             task_id = self.next_task_id
             self.tasks[task_id] = {
                 "id": task_id,
                 "title": title,
                 "priority": priority,
                 "completed": False
             }
             self.next_task_id += 1
             return task_id
     
         def complete_task(self, task_id):
             if task_id in self.tasks:
                 self.tasks[task_id]["completed"] = True
     
         def list_tasks(self, filter_by=None):
             filtered_tasks = []
             for task in self.tasks.values():
                 if filter_by is None:
                     filtered_tasks.append(task)
                 elif filter_by == "pending" and not task["completed"]:
                     filtered_tasks.append(task)
                 elif filter_by == "completed" and task["completed"]:
                     filtered_tasks.append(task)
             return filtered_tasks
     
         def get_stats(self):
             total_tasks = len(self.tasks)
             completed_tasks = sum(1 for task in self.tasks.values() if task["completed"])
             pending_tasks = total_tasks - completed_tasks
             return {
                 "total": total_tasks,
                 "completed": completed_tasks,
                 "pending": pending_tasks
             }
     ```
