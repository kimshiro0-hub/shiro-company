     import pytest
     from task_manager import TaskManager
     
     def test_add_task():
         tm = TaskManager()
         task_id = tm.add_task("테스트 태스크")
         assert task_id == 1
         assert len(tm.tasks) == 1
     
     def test_add_task_with_priority():
         tm = TaskManager()
         tm.add_task("중요한 일", "high")
         assert tm.tasks[1]["priority"] == "high"
     
     def test_complete_task():
         tm = TaskManager()
         task_id = tm.add_task("완료할 일")
         tm.complete_task(task_id)
         assert tm.tasks[task_id]["completed"] == True
     
     def test_list_tasks_all():
         tm = TaskManager()
         tm.add_task("일반 태스크")
         tm.add_task("완료된 태스크")
         tm.complete_task(2)
         tasks = tm.list_tasks()
         assert len(tasks) == 2
     
     def test_list_tasks_pending_only():
         tm = TaskManager()
         tm.add_task("미완료 태스크")
         tm.add_task("완료된 태스크")
         tm.complete_task(2)
         pending = tm.list_tasks("pending")
         assert len(pending) == 1
     
     def test_list_tasks_completed_only():
         tm = TaskManager()
         tm.add_task("미완료 태스크")
         tm.add_task("완료된 태스크")
         tm.complete_task(2)
         completed = tm.list_tasks("completed")
         assert len(completed) == 1
     
     def test_get_stats():
         tm = TaskManager()
         tm.add_task("태스크1")
         tm.add_task("태스크2")
         tm.complete_task(1)
         stats = tm.get_stats()
         assert stats["total"] == 2
         assert stats["completed"] == 1
         assert stats["pending"] == 1
     
     def test_complete_nonexistent_task():
         tm = TaskManager()
         with pytest.raises(KeyError):
             tm.complete_task(999)
     
     def test_empty_title():
         tm = TaskManager()
         with pytest.raises(ValueError):
             tm.add_task("")
     
     def test_invalid_priority():
         tm = TaskManager()
         with pytest.raises(ValueError):
             tm.add_task("태스크", "invalid_priority")
